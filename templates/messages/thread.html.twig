{% extends 'base.html.twig' %}

{% block title %}Conversation{% endblock %}

{% block body %}
    <h1>Conversation avec {{ other.username }}</h1>

    {% if thread is empty %}
        <p class="muted">Aucun message pour le moment.</p>
    {% endif %}

    {% for m in thread %}
        <div class="card">
            <div class="muted">
                <strong>{{ m.sender.username }}</strong>
                <span>·</span>
                <span>{{ m.createdAt|date('d/m/Y H:i') }}</span>
                {% if m.recipient.id == app.user.id and not m.isRead %}
                    <span>·</span>
                    <span>non lu</span>
                {% endif %}
            </div>
            <p>{{ m.content }}</p>
        </div>
    {% endfor %}

    <div class="card">
        {{ form_start(form) }}
        {{ form_row(form.content, { label: 'Répondre' }) }}
        <button type="submit">Envoyer</button>
        {{ form_end(form) }}
    </div>
{% endblock %}

