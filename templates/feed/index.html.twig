{% extends 'base.html.twig' %}

{% block title %}Feed{% endblock %}

{% block body %}
    <h1>Fil d'actualité</h1>

    {% if followingCount == 0 %}
        <p class="muted">Vous ne suivez personne pour l'instant. Allez sur un profil et commencez à suivre des gens.</p>
    {% endif %}

    {% if posts is empty %}
        <p class="muted">Aucun post à afficher.</p>
    {% endif %}

    {% for post in posts %}
        <article class="card">
            <div class="muted">
                <a href="{{ path('app_profile_show', { username: post.author.username }) }}">{{ post.author.username }}</a>
                <span>·</span>
                <span>{{ post.createdAt|date('d/m/Y H:i') }}</span>
            </div>
            <p>{{ post.content }}</p>

            <div class="muted">
                <span>{{ post.likedBy|length }} likes</span>
                {% set hasLiked = false %}
                {% for u in post.likedBy %}
                    {% if u.id == app.user.id %}
                        {% set hasLiked = true %}
                    {% endif %}
                {% endfor %}

                <form method="post" action="{{ path('app_post_like_toggle', { id: post.id }) }}" style="display: inline;">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('like' ~ post.id) }}">
                    <button type="submit">{{ hasLiked ? 'Ne plus liker' : 'Liker' }}</button>
                </form>
            </div>

            {% if is_granted('POST_DELETE', post) %}
                <form method="post" action="{{ path('app_post_delete', { id: post.id }) }}" style="display: inline;">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete' ~ post.id) }}">
                    <button type="submit">Supprimer</button>
                </form>
            {% endif %}
        </article>
    {% endfor %}
{% endblock %}

