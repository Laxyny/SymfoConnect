<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}SymfoConnect{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 16 16%22><rect width=%2216%22 height=%2216%22 fill=%22%23000%22 /></svg>">
        {% block stylesheets %}
            <style>
                :root{
                    --bg: #f6f7fb;
                    --surface: #ffffff;
                    --text: #0f172a;
                    --muted: #64748b;
                    --border: #e6e8ef;
                    --shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
                    --radius: 14px;
                    --radius-sm: 10px;
                    --ring: 0 0 0 4px rgba(59, 130, 246, 0.18);
                    --primary: #2563eb;
                    --primary-hover: #1d4ed8;
                    --success-bg: #e7f7ee;
                    --success-border: #bfe8d0;
                    --danger-bg: #fdeaea;
                    --danger-border: #f4bcbc;
                }

                *{ box-sizing: border-box; }
                html, body{ height: 100%; }
                body{
                    margin: 0;
                    font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
                    color: var(--text);
                    background: linear-gradient(180deg, #eef2ff 0%, var(--bg) 55%, var(--bg) 100%);
                    line-height: 1.45;
                }

                .container{
                    max-width: 980px;
                    margin: 0 auto;
                    padding: 28px 16px;
                }

                header{
                    background: rgba(255, 255, 255, 0.85);
                    border-bottom: 1px solid var(--border);
                    backdrop-filter: blur(10px);
                    position: sticky;
                    top: 0;
                    z-index: 10;
                }

                nav{
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 16px;
                    padding: 14px 16px;
                    max-width: 980px;
                    margin: 0 auto;
                }

                nav a{
                    color: var(--text);
                    text-decoration: none;
                    font-weight: 650;
                }

                nav a:hover{ text-decoration: underline; text-underline-offset: 4px; }
                nav a:focus-visible{ outline: none; box-shadow: var(--ring); border-radius: 8px; }

                nav .links{
                    display: flex;
                    gap: 12px;
                    align-items: center;
                    flex-wrap: wrap;
                    justify-content: flex-end;
                }

                .nav-brand{
                    display: inline-flex;
                    align-items: center;
                    gap: 10px;
                }

                .nav-icon{
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    width: 40px;
                    height: 40px;
                    border-radius: 999px;
                    border: 1px solid #d7dbe6;
                    background: rgba(255, 255, 255, 0.75);
                    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.04);
                }

                .nav-icon:hover{
                    background: #f8fafc;
                    text-decoration: none;
                }

                .nav-icon svg{
                    width: 18px;
                    height: 18px;
                }

                .nav-label{
                    display: none;
                }

                @media (max-width: 780px){
                    .nav-label{ display: none; }
                }

                .flash{
                    padding: 12px 14px;
                    border-radius: var(--radius-sm);
                    margin: 12px 0;
                    border: 1px solid var(--border);
                    background: var(--surface);
                    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.03);
                }

                .flash-success{ background: var(--success-bg); border-color: var(--success-border); }
                .flash-danger{ background: var(--danger-bg); border-color: var(--danger-border); }

                .card{
                    background: var(--surface);
                    border: 1px solid var(--border);
                    border-radius: var(--radius);
                    padding: 16px;
                    margin: 12px 0;
                    box-shadow: var(--shadow);
                }

                .muted{ color: var(--muted); font-size: 14px; font-weight: 500; }

                .card-header{
                    display: flex;
                    gap: 12px;
                    align-items: center;
                    flex-wrap: wrap;
                    justify-content: flex-start;
                }

                .profile-card{ padding: 18px; }

                .profile-top{
                    display: grid;
                    grid-template-columns: 96px 1fr auto;
                    gap: 16px;
                    align-items: start;
                }

                .avatar{
                    width: 96px;
                    height: 96px;
                    border-radius: 16px;
                    object-fit: cover;
                    border: 1px solid var(--border);
                    box-shadow: 0 10px 18px rgba(15, 23, 42, 0.08);
                    background: #fff;
                }

                .profile-meta{ display: grid; gap: 8px; }
                .profile-title{ margin: 0; font-size: 28px; letter-spacing: -0.02em; }
                .profile-stats{ display: flex; gap: 10px; flex-wrap: wrap; }

                .profile-actions{
                    display: flex;
                    gap: 10px;
                    align-items: center;
                    flex-wrap: wrap;
                    justify-content: flex-end;
                }

                .icon-btn{
                    width: 40px;
                    height: 40px;
                    padding: 0;
                    border-radius: 999px;
                }

                details.dropdown{ width: 100%; margin-top: 14px; }

                details.dropdown > summary{
                    list-style: none;
                    cursor: pointer;
                    user-select: none;
                }

                details.dropdown > summary::-webkit-details-marker{ display: none; }

                .dropdown-panel{
                    margin-top: 10px;
                    padding: 14px;
                    border: 1px solid var(--border);
                    border-radius: var(--radius);
                    background: rgba(255, 255, 255, 0.7);
                    backdrop-filter: blur(8px);
                }

                .author-link{
                    color: var(--text);
                    font-weight: 650;
                    text-decoration: none;
                }
                .author-link:hover{ text-decoration: underline; text-underline-offset: 4px; }
                .author-link:focus-visible{ outline: none; box-shadow: var(--ring); border-radius: 8px; }

                .post-footer{
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 12px;
                    margin-top: 12px;
                }

                .post-date{
                    margin-left: auto;
                    text-align: right;
                    white-space: nowrap;
                }

                input, textarea{
                    width: 100%;
                    padding: 10px 12px;
                    border: 1px solid #d7dbe6;
                    border-radius: var(--radius-sm);
                    background: var(--surface);
                    color: var(--text);
                }

                textarea{ resize: vertical; min-height: 110px; }

                input:focus, textarea:focus{
                    outline: none;
                    border-color: rgba(59, 130, 246, 0.55);
                    box-shadow: var(--ring);
                }

                button{
                    appearance: none;
                    font: inherit;
                    cursor: pointer;
                }

                /* Fallback for buttons without .btn class */
                button:not(.btn){
                    background: var(--primary);
                    color: #fff;
                    border: 0;
                    border-radius: var(--radius-sm);
                    padding: 10px 14px;
                    font-weight: 700;
                    transition: transform 120ms ease, background 120ms ease;
                    box-shadow: 0 10px 18px rgba(37, 99, 235, 0.18);
                }
                button:not(.btn):hover{ background: var(--primary-hover); }
                button:not(.btn):active{ transform: translateY(1px); }
                button:not(.btn):focus-visible{ outline: none; box-shadow: var(--ring), 0 10px 18px rgba(37, 99, 235, 0.18); }

                .btn{
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    gap: 8px;
                    min-height: 38px;
                    padding: 9px 14px;
                    border-radius: 999px;
                    font-weight: 700;
                    border: 1px solid transparent;
                    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.06), 0 10px 18px rgba(15, 23, 42, 0.06);
                    text-decoration: none;
                    user-select: none;
                    transition: transform 120ms ease, background 120ms ease, border-color 120ms ease, box-shadow 120ms ease;
                }

                .btn:hover{ transform: translateY(-1px); }
                .btn:active{ transform: translateY(0px); }
                .btn:focus-visible{ outline: none; box-shadow: var(--ring), 0 10px 18px rgba(15, 23, 42, 0.08); }

                .btn-primary{
                    background: linear-gradient(180deg, #3b82f6 0%, var(--primary) 60%, #1d4ed8 100%);
                    color: #fff;
                    border-color: rgba(29, 78, 216, 0.35);
                }
                .btn-primary:hover{
                    background: linear-gradient(180deg, #2563eb 0%, #1d4ed8 100%);
                }

                .btn-secondary{
                    background: #ffffff;
                    color: var(--text);
                    border-color: #d7dbe6;
                    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.04);
                }
                .btn-secondary:hover{ background: #f8fafc; }

                .btn-danger{
                    background: linear-gradient(180deg, #fb7185 0%, #ef4444 55%, #dc2626 100%);
                    color: #fff;
                    border-color: rgba(220, 38, 38, 0.55);
                }
                .btn-danger:hover{
                    background: linear-gradient(180deg, #f43f5e 0%, #dc2626 100%);
                }

                .inline-form{ display: inline; }

                .action-row{
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    flex-wrap: wrap;
                }

                @media (max-width: 640px){
                    .container{ padding: 20px 14px; }
                    nav{ padding: 12px 14px; }
                    .profile-top{ grid-template-columns: 72px 1fr; }
                    .avatar{ width: 72px; height: 72px; border-radius: 14px; }
                    .profile-actions{ grid-column: 1 / -1; justify-content: flex-start; }
                }
            </style>
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <header>
            <nav>
                <a class="nav-brand" href="{{ path('app_home') }}" aria-label="Accueil SymfoConnect">
                    <svg width="24" height="24" viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
                        <path d="M12 2.5c-4.7 0-8.5 3.6-8.5 8.1 0 3 1.7 5.7 4.3 7.1V21l2.2-1.1c.6.1 1.2.2 2 .2 4.7 0 8.5-3.6 8.5-8.1S16.7 2.5 12 2.5Zm0 14.1c-.7 0-1.3-.1-1.8-.2l-.5-.1-1.3.7v-1.2l-.4-.2c-2.1-1-3.4-3.1-3.4-5.4 0-3.4 3.1-6.2 6.9-6.2s6.9 2.8 6.9 6.2-3.1 6.2-6.9 6.2Z" fill="currentColor"/>
                    </svg>
                    <span>SymfoConnect</span>
                </a>
                <div class="links">
                    {% if app.user %}
                        <a class="nav-icon" href="{{ path('app_profile_show', { username: app.user.username }) }}" aria-label="Mon profil">
                            <svg viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
                                <path d="M12 12.2c2.5 0 4.6-2 4.6-4.5S14.5 3.2 12 3.2 7.4 5.2 7.4 7.7s2.1 4.5 4.6 4.5Zm0 2.2c-4.2 0-7.6 2.6-7.6 5.8V21h15.2v-.8c0-3.2-3.4-5.8-7.6-5.8Z" fill="currentColor"/>
                            </svg>
                        </a>
                        <a class="nav-icon" href="{{ path('app_notifications') }}" aria-label="Notifications">
                            <svg viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
                                <path d="M12 22a2.3 2.3 0 0 0 2.3-2.3h-4.6A2.3 2.3 0 0 0 12 22Zm7-6.2V11a7 7 0 0 0-5.8-6.9V3a1.2 1.2 0 0 0-2.4 0v1.1A7 7 0 0 0 5 11v4.8L3.4 17.4V19h17.2v-1.6L19 15.8Z" fill="currentColor"/>
                            </svg>
                        </a>
                        <a class="nav-icon" href="{{ path('app_feed') }}" aria-label="Feed">
                            <svg viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
                                <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h10v2H4v-2Z" fill="currentColor"/>
                            </svg>
                        </a>
                        <a class="nav-icon" href="{{ path('app_messages') }}" aria-label="Messages">
                            <svg viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
                                <path d="M20 4H4a2 2 0 0 0-2 2v14l4-3h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 11H5.2L4 16V6h16v9Z" fill="currentColor"/>
                            </svg>
                        </a>
                        <a class="nav-icon" href="{{ path('app_post_new') }}" aria-label="Nouveau post">
                            <svg viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
                                <path d="M19 11h-6V5h-2v6H5v2h6v6h2v-6h6v-2Z" fill="currentColor"/>
                            </svg>
                        </a>
                        <a class="nav-icon" href="{{ path('app_logout') }}" aria-label="Déconnexion">
                            <svg viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
                                <path d="M10 17v-2h4V9h-4V7h4a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-4Zm-1-1-5-4 5-4v3h6v2H9v3Z" fill="currentColor"/>
                            </svg>
                        </a>
                    {% else %}
                        <a class="nav-icon" href="{{ path('app_login') }}" aria-label="Connexion">
                            <svg viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
                                <path d="M14 17v-2h2V9h-2V7h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-2ZM11 16l-5-4 5-4v3h6v2h-6v3Z" fill="currentColor"/>
                            </svg>
                        </a>
                        <a class="nav-icon" href="{{ path('app_register') }}" aria-label="Inscription">
                            <svg viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
                                <path d="M12 12.2c2.5 0 4.6-2 4.6-4.5S14.5 3.2 12 3.2 7.4 5.2 7.4 7.7s2.1 4.5 4.6 4.5Zm0 2.2c-4.2 0-7.6 2.6-7.6 5.8V21h10.2v-2H6.8c.5-1.6 2.6-2.6 5.2-2.6 1.1 0 2.1.2 3 .6l.8-1.7c-1.1-.5-2.4-.9-3.8-.9Zm8.5 2.3V15h-1.8v1.5h-1.5v1.8h1.5v1.5h1.8v-1.5H22v-1.8h-1.5Z" fill="currentColor"/>
                            </svg>
                        </a>
                    {% endif %}
                </div>
            </nav>
        </header>

        <main class="container">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash-{{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>
    </body>
</html>
