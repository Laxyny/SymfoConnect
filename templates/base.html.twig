<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}SymfoConnect{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 16 16%22><rect width=%2216%22 height=%2216%22 fill=%22%23000%22 /></svg>">
        {% block stylesheets %}
            <style>
                body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 0; background: #f6f7fb; color: #111; }
                .container { max-width: 960px; margin: 0 auto; padding: 24px 16px; }
                header { background: #fff; border-bottom: 1px solid #e6e8ef; }
                nav { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 14px 16px; max-width: 960px; margin: 0 auto; }
                nav a { color: #111; text-decoration: none; font-weight: 600; }
                nav .links { display: flex; gap: 12px; align-items: center; }
                .flash { padding: 10px 12px; border-radius: 8px; margin: 12px 0; }
                .flash-success { background: #e7f7ee; border: 1px solid #bfe8d0; }
                .flash-danger { background: #fdeaea; border: 1px solid #f4bcbc; }
                .card { background: #fff; border: 1px solid #e6e8ef; border-radius: 12px; padding: 14px; margin: 12px 0; }
                .muted { color: #666; font-size: 14px; }
                textarea, input { width: 100%; padding: 10px 12px; border: 1px solid #d7dbe6; border-radius: 10px; box-sizing: border-box; }
                button { background: #111; color: #fff; border: 0; border-radius: 10px; padding: 10px 14px; font-weight: 600; cursor: pointer; }
                button:hover { opacity: 0.9; }
            </style>
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <header>
            <nav>
                <a href="{{ path('app_home') }}">SymfoConnect</a>
                <div class="links">
                    <a href="{{ path('app_post_new') }}">Nouveau post</a>
                </div>
            </nav>
        </header>

        <main class="container">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash-{{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>
    </body>
</html>
