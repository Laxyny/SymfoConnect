<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}SymfoConnect{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 16 16%22><rect width=%2216%22 height=%2216%22 fill=%22%23000%22 /></svg>">
        {% block stylesheets %}
            <style>
                :root{
                    --bg: #f6f7fb;
                    --surface: #ffffff;
                    --text: #0f172a;
                    --muted: #64748b;
                    --border: #e6e8ef;
                    --shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
                    --radius: 14px;
                    --radius-sm: 10px;
                    --ring: 0 0 0 4px rgba(59, 130, 246, 0.18);
                    --primary: #2563eb;
                    --primary-hover: #1d4ed8;
                    --success-bg: #e7f7ee;
                    --success-border: #bfe8d0;
                    --danger-bg: #fdeaea;
                    --danger-border: #f4bcbc;
                }

                *{ box-sizing: border-box; }
                html, body{ height: 100%; }
                body{
                    margin: 0;
                    font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
                    color: var(--text);
                    background: linear-gradient(180deg, #eef2ff 0%, var(--bg) 55%, var(--bg) 100%);
                    line-height: 1.45;
                }

                .container{
                    max-width: 980px;
                    margin: 0 auto;
                    padding: 28px 16px;
                }

                header{
                    background: rgba(255, 255, 255, 0.85);
                    border-bottom: 1px solid var(--border);
                    backdrop-filter: blur(10px);
                    position: sticky;
                    top: 0;
                    z-index: 10;
                }

                nav{
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 16px;
                    padding: 14px 16px;
                    max-width: 980px;
                    margin: 0 auto;
                }

                nav a{
                    color: var(--text);
                    text-decoration: none;
                    font-weight: 650;
                }

                nav a:hover{ text-decoration: underline; text-underline-offset: 4px; }
                nav a:focus-visible{ outline: none; box-shadow: var(--ring); border-radius: 8px; }

                nav .links{
                    display: flex;
                    gap: 12px;
                    align-items: center;
                    flex-wrap: wrap;
                    justify-content: flex-end;
                }

                .flash{
                    padding: 12px 14px;
                    border-radius: var(--radius-sm);
                    margin: 12px 0;
                    border: 1px solid var(--border);
                    background: var(--surface);
                    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.03);
                }

                .flash-success{ background: var(--success-bg); border-color: var(--success-border); }
                .flash-danger{ background: var(--danger-bg); border-color: var(--danger-border); }

                .card{
                    background: var(--surface);
                    border: 1px solid var(--border);
                    border-radius: var(--radius);
                    padding: 16px;
                    margin: 12px 0;
                    box-shadow: var(--shadow);
                }

                .muted{ color: var(--muted); font-size: 14px; font-weight: 500; }

                .card-header{
                    display: flex;
                    gap: 12px;
                    align-items: center;
                    flex-wrap: wrap;
                    justify-content: flex-start;
                }

                .profile-card{ padding: 18px; }

                .profile-top{
                    display: grid;
                    grid-template-columns: 96px 1fr auto;
                    gap: 16px;
                    align-items: start;
                }

                .avatar{
                    width: 96px;
                    height: 96px;
                    border-radius: 16px;
                    object-fit: cover;
                    border: 1px solid var(--border);
                    box-shadow: 0 10px 18px rgba(15, 23, 42, 0.08);
                    background: #fff;
                }

                .profile-meta{ display: grid; gap: 8px; }
                .profile-title{ margin: 0; font-size: 28px; letter-spacing: -0.02em; }
                .profile-stats{ display: flex; gap: 10px; flex-wrap: wrap; }

                .profile-actions{
                    display: flex;
                    gap: 10px;
                    align-items: center;
                    flex-wrap: wrap;
                    justify-content: flex-end;
                }

                .icon-btn{
                    width: 40px;
                    height: 40px;
                    padding: 0;
                    border-radius: 999px;
                }

                details.dropdown{ width: 100%; margin-top: 14px; }

                details.dropdown > summary{
                    list-style: none;
                    cursor: pointer;
                    user-select: none;
                }

                details.dropdown > summary::-webkit-details-marker{ display: none; }

                .dropdown-panel{
                    margin-top: 10px;
                    padding: 14px;
                    border: 1px solid var(--border);
                    border-radius: var(--radius);
                    background: rgba(255, 255, 255, 0.7);
                    backdrop-filter: blur(8px);
                }

                .author-link{
                    color: var(--text);
                    font-weight: 650;
                    text-decoration: none;
                }
                .author-link:hover{ text-decoration: underline; text-underline-offset: 4px; }
                .author-link:focus-visible{ outline: none; box-shadow: var(--ring); border-radius: 8px; }

                .post-footer{
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 12px;
                    margin-top: 12px;
                }

                .post-date{
                    margin-left: auto;
                    text-align: right;
                    white-space: nowrap;
                }

                input, textarea{
                    width: 100%;
                    padding: 10px 12px;
                    border: 1px solid #d7dbe6;
                    border-radius: var(--radius-sm);
                    background: var(--surface);
                    color: var(--text);
                }

                textarea{ resize: vertical; min-height: 110px; }

                input:focus, textarea:focus{
                    outline: none;
                    border-color: rgba(59, 130, 246, 0.55);
                    box-shadow: var(--ring);
                }

                button{
                    appearance: none;
                    font: inherit;
                    cursor: pointer;
                }

                /* Fallback for buttons without .btn class */
                button:not(.btn){
                    background: var(--primary);
                    color: #fff;
                    border: 0;
                    border-radius: var(--radius-sm);
                    padding: 10px 14px;
                    font-weight: 700;
                    transition: transform 120ms ease, background 120ms ease;
                    box-shadow: 0 10px 18px rgba(37, 99, 235, 0.18);
                }
                button:not(.btn):hover{ background: var(--primary-hover); }
                button:not(.btn):active{ transform: translateY(1px); }
                button:not(.btn):focus-visible{ outline: none; box-shadow: var(--ring), 0 10px 18px rgba(37, 99, 235, 0.18); }

                .btn{
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    gap: 8px;
                    min-height: 38px;
                    padding: 9px 14px;
                    border-radius: 999px;
                    font-weight: 700;
                    border: 1px solid transparent;
                    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.06), 0 10px 18px rgba(15, 23, 42, 0.06);
                    text-decoration: none;
                    user-select: none;
                    transition: transform 120ms ease, background 120ms ease, border-color 120ms ease, box-shadow 120ms ease;
                }

                .btn:hover{ transform: translateY(-1px); }
                .btn:active{ transform: translateY(0px); }
                .btn:focus-visible{ outline: none; box-shadow: var(--ring), 0 10px 18px rgba(15, 23, 42, 0.08); }

                .btn-primary{
                    background: linear-gradient(180deg, #3b82f6 0%, var(--primary) 60%, #1d4ed8 100%);
                    color: #fff;
                    border-color: rgba(29, 78, 216, 0.35);
                }
                .btn-primary:hover{
                    background: linear-gradient(180deg, #2563eb 0%, #1d4ed8 100%);
                }

                .btn-secondary{
                    background: #ffffff;
                    color: var(--text);
                    border-color: #d7dbe6;
                    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.04);
                }
                .btn-secondary:hover{ background: #f8fafc; }

                .btn-danger{
                    background: linear-gradient(180deg, #fb7185 0%, #ef4444 55%, #dc2626 100%);
                    color: #fff;
                    border-color: rgba(220, 38, 38, 0.55);
                }
                .btn-danger:hover{
                    background: linear-gradient(180deg, #f43f5e 0%, #dc2626 100%);
                }

                .inline-form{ display: inline; }

                .action-row{
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    flex-wrap: wrap;
                }

                @media (max-width: 640px){
                    .container{ padding: 20px 14px; }
                    nav{ padding: 12px 14px; }
                    .profile-top{ grid-template-columns: 72px 1fr; }
                    .avatar{ width: 72px; height: 72px; border-radius: 14px; }
                    .profile-actions{ grid-column: 1 / -1; justify-content: flex-start; }
                }
            </style>
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <header>
            <nav>
                <a href="{{ path('app_home') }}">SymfoConnect</a>
                <div class="links">
                    {% if app.user %}
                        <a href="{{ path('app_profile_show', { username: app.user.username }) }}">{{ app.user.username }}</a>
                        <a href="{{ path('app_feed') }}">Feed</a>
                        <a href="{{ path('app_post_new') }}">Nouveau post</a>
                        <a href="{{ path('app_logout') }}">Déconnexion</a>
                    {% else %}
                        <a href="{{ path('app_login') }}">Connexion</a>
                        <a href="{{ path('app_register') }}">Inscription</a>
                    {% endif %}
                </div>
            </nav>
        </header>

        <main class="container">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash-{{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>
    </body>
</html>
