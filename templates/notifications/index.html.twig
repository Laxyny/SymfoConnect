{% extends 'base.html.twig' %}

{% block title %}Notifications{% endblock %}

{% block body %}
    <h1>Notifications</h1>

    {% if notifications is empty %}
        <p class="muted">Aucune notification.</p>
    {% endif %}

    {% for n in notifications %}
        <div class="card">
            <div class="muted">{{ n.createdAt|date('d/m/Y H:i') }}</div>
            <p>{{ n.content }}</p>
            <form method="post" action="{{ path('app_notification_delete', { id: n.id }) }}" class="inline-form">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete_notification' ~ n.id) }}">
                <button type="submit" class="btn btn-danger" aria-label="Supprimer la notification">
                    <svg viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false" style="width:16px;height:16px;">
                        <path d="M9 3h6l1 2h4v2H4V5h4l1-2Zm1 7h2v9h-2v-9Zm4 0h2v9h-2v-9ZM6 8h12l-1 13H7L6 8Z" fill="currentColor"/>
                    </svg>
                    <span>Supprimer</span>
                </button>
            </form>
        </div>
    {% endfor %}
{% endblock %}

