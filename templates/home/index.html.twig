{% extends 'base.html.twig' %}

{% block title %}Accueil · SymfoConnect{% endblock %}

{% block body %}
    {% if not app.user %}
        <section class="hero">
            <span class="badge">Nouveau · Rejoins la communauté</span>
            <h1 style="margin-top:14px;">Connecte-toi à la <span class="gradient-text">communauté Symfony</span>.</h1>
            <p>Partage tes projets, suis les développeurs qui t'inspirent et échange en temps réel. Une expérience sociale moderne, pensée pour les développeurs.</p>
            <div class="hero-actions">
                <a class="btn btn-primary btn-lg" href="{{ path('app_register') }}">Créer mon compte</a>
                <a class="btn btn-secondary btn-lg" href="{{ path('app_login') }}">J'ai déjà un compte</a>
            </div>
        </section>
    {% endif %}

    <div class="page-header">
        <div>
            <h1>Derniers posts</h1>
            <p class="page-subtitle">Découvre ce que la communauté publie en ce moment.</p>
        </div>
        {% if app.user %}
            <a href="{{ path('app_post_new') }}" class="btn btn-primary">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
                Nouveau post
            </a>
        {% endif %}
    </div>

    {% if posts is empty %}
        <div class="empty">
            <span class="empty-icon">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </span>
            <h3>Aucun post pour le moment</h3>
            <p>Sois le premier à publier quelque chose.</p>
        </div>
    {% endif %}

    <div class="stack">
        {% for post in posts %}
            <article class="card post-card">
                <div class="post-head">
                    <a class="avatar-inline" href="{{ path('app_profile_show', { username: post.author.username }) }}" aria-hidden="true">
                        {% if post.author.avatarUrl %}
                            <img src="{{ post.author.avatarUrl }}" alt="">
                        {% else %}
                            {{ post.author.username|slice(0, 1)|upper }}
                        {% endif %}
                    </a>
                    <div class="post-author">
                        <a class="author-link" href="{{ path('app_profile_show', { username: post.author.username }) }}">{{ post.author.username }}</a>
                        <span class="muted" style="font-size:12px;">{{ post.createdAt|date('d/m/Y · H:i') }}</span>
                    </div>
                </div>

                <p class="post-content">{{ post.content }}</p>

                <div class="post-footer">
                    <div class="action-row">
                        {% if app.user %}
                            {% set hasLiked = false %}
                            {% for u in post.likedBy %}
                                {% if u.id == app.user.id %}{% set hasLiked = true %}{% endif %}
                            {% endfor %}
                            <form method="post" action="{{ path('app_post_like_toggle', { id: post.id }) }}" class="inline-form">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('like' ~ post.id) }}">
                                <button type="submit" class="like-btn {{ hasLiked ? 'is-liked' : '' }}" aria-label="{{ hasLiked ? 'Ne plus liker' : 'Liker' }}">
                                    <svg viewBox="0 0 24 24" fill="{{ hasLiked ? 'currentColor' : 'none' }}" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M12 20s-7-4.5-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.5-7 10-7 10Z"/>
                                    </svg>
                                    <span>{{ post.likedBy|length }}</span>
                                </button>
                            </form>
                        {% else %}
                            <span class="muted" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:16px;height:16px;" aria-hidden="true"><path d="M12 20s-7-4.5-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.5-7 10-7 10Z"/></svg>
                                {{ post.likedBy|length }}
                            </span>
                        {% endif %}

                        {% if is_granted('POST_DELETE', post) %}
                            <form method="post" action="{{ path('app_post_delete', { id: post.id }) }}" class="inline-form">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete' ~ post.id) }}">
                                <button type="submit" class="btn btn-ghost btn-sm" aria-label="Supprimer le post">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16M9 7V5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2m-8 0 1 13a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2l1-13"/></svg>
                                    Supprimer
                                </button>
                            </form>
                        {% endif %}
                    </div>
                    <div class="post-date">{{ post.createdAt|date('d/m/Y H:i') }}</div>
                </div>
            </article>
        {% endfor %}
    </div>
{% endblock %}
