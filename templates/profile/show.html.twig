{% extends 'base.html.twig' %}

{% block title %}Profil{% endblock %}

{% block body %}
    <h1>Profil de {{ profileUser.username }}</h1>

    <section class="card">
        {% if profileUser.avatarUrl %}
            <img src="{{ profileUser.avatarUrl }}" alt="{{ profileUser.username }}" style="max-width: 96px; border-radius: 12px;">
        {% endif %}

        {% if profileUser.bio %}
            <p>{{ profileUser.bio }}</p>
        {% else %}
            <p class="muted">Aucune bio.</p>
        {% endif %}
    </section>

    <h2>Posts</h2>
    {% if posts is empty %}
        <p class="muted">Aucun post.</p>
    {% endif %}

    {% for post in posts %}
        <article class="card">
            <div class="muted">{{ post.createdAt|date('d/m/Y H:i') }}</div>
            <p>{{ post.content }}</p>
        </article>
    {% endfor %}
{% endblock %}

