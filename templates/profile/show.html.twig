{% extends 'base.html.twig' %}

{% block title %}Profil{% endblock %}

{% block body %}
    <h1>Profil de {{ profileUser.username }}</h1>

    <section class="card">
        {% if profileUser.avatarUrl %}
            <img src="{{ profileUser.avatarUrl }}" alt="{{ profileUser.username }}" style="max-width: 96px; border-radius: 12px;">
        {% endif %}

        {% if profileUser.bio %}
            <p>{{ profileUser.bio }}</p>
        {% else %}
            <p class="muted">Aucune bio.</p>
        {% endif %}

        <p class="muted">
            <span>{{ followersCount }} followers</span>
            <span>·</span>
            <span>{{ followingCount }} follows</span>
        </p>

        {% if editForm %}
            <h2>Modifier mon profil</h2>
            <div class="card">
                {{ form_start(editForm) }}
                {{ form_row(editForm.bio, { label: 'Bio' }) }}
                {{ form_row(editForm.avatarUrl, { label: 'URL avatar' }) }}
                <button type="submit" class="btn btn-primary">Enregistrer</button>
                {{ form_end(editForm) }}
            </div>
        {% endif %}
        {% if app.user %}
            {% if app.user.id != profileUser.id %}
                {% if isFollowing %}
                    <form method="post" action="{{ path('app_profile_unfollow', { username: profileUser.username }) }}" class="inline-form">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('unfollow' ~ profileUser.id) }}">
                        <button type="submit" class="btn btn-secondary">Ne plus suivre</button>
                    </form>
                {% else %}
                    <form method="post" action="{{ path('app_profile_follow', { username: profileUser.username }) }}" class="inline-form">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('follow' ~ profileUser.id) }}">
                        <button type="submit" class="btn btn-primary">Suivre</button>
                    </form>
                {% endif %}
            {% endif %}
        {% endif %}
    </section>

    <h2>Posts</h2>
    {% if posts is empty %}
        <p class="muted">Aucun post.</p>
    {% endif %}

    {% for post in posts %}
        <article class="card">
            <p>{{ post.content }}</p>

            <div class="post-footer">
                <div class="muted action-row">
                    <span>{{ post.likedBy|length }} likes</span>
                    {% if app.user %}
                        {% set hasLiked = false %}
                        {% for u in post.likedBy %}
                            {% if u.id == app.user.id %}
                                {% set hasLiked = true %}
                            {% endif %}
                        {% endfor %}

                        <form method="post" action="{{ path('app_post_like_toggle', { id: post.id }) }}" class="inline-form">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('like' ~ post.id) }}">
                            <button type="submit" class="btn {{ hasLiked ? 'btn-secondary' : 'btn-primary' }}">
                                {{ hasLiked ? 'Ne plus liker' : 'Liker' }}
                            </button>
                        </form>
                    {% endif %}

                    {% if is_granted('POST_DELETE', post) %}
                        <form method="post" action="{{ path('app_post_delete', { id: post.id }) }}" class="inline-form">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete' ~ post.id) }}">
                            <button type="submit" class="btn btn-danger">Supprimer</button>
                        </form>
                    {% endif %}
                </div>

                <div class="muted post-date">{{ post.createdAt|date('d/m/Y H:i') }}</div>
            </div>
        </article>
    {% endfor %}
{% endblock %}

