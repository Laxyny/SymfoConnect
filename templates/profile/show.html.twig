{% extends 'base.html.twig' %}

{% block title %}{{ profileUser.username }} · SymfoConnect{% endblock %}

{% block body %}
    <section class="card profile-card">
        <div class="profile-cover" aria-hidden="true"></div>
        <div class="profile-body">
            {% if profileUser.avatarUrl %}
                <img class="avatar" src="{{ profileUser.avatarUrl }}" alt="{{ profileUser.username }}">
            {% else %}
                <div class="avatar avatar-placeholder" aria-hidden="true">
                    {{ profileUser.username|slice(0, 1)|upper }}
                </div>
            {% endif %}

            <div class="profile-meta">
                <h1 class="profile-title">{{ profileUser.username }}</h1>

                {% if profileUser.bio %}
                    <p style="margin:0;color:var(--text-soft);">{{ profileUser.bio }}</p>
                {% else %}
                    <p class="muted" style="margin:0;">Aucune bio pour le moment.</p>
                {% endif %}

                <div class="profile-stats">
                    <span><strong>{{ followersCount }}</strong> followers</span>
                    <span><strong>{{ followingCount }}</strong> follows</span>
                    <span><strong>{{ posts|length }}</strong> posts</span>
                </div>
            </div>

            <div class="profile-actions">
                {% if app.user and app.user.id != profileUser.id %}
                    <a href="{{ path('app_messages_thread', { username: profileUser.username }) }}" class="btn btn-secondary">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 5h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H8l-4 4V6a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                        Message
                    </a>
                    {% if isFollowing %}
                        <form method="post" action="{{ path('app_profile_unfollow', { username: profileUser.username }) }}" class="inline-form">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('unfollow' ~ profileUser.id) }}">
                            <button type="submit" class="btn btn-secondary">
                                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                                Suivi
                            </button>
                        </form>
                    {% else %}
                        <form method="post" action="{{ path('app_profile_follow', { username: profileUser.username }) }}" class="inline-form">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('follow' ~ profileUser.id) }}">
                            <button type="submit" class="btn btn-primary">
                                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
                                Suivre
                            </button>
                        </form>
                    {% endif %}
                {% endif %}

                {% if editForm %}
                    <a href="#edit-profile" class="btn btn-secondary icon-btn" title="Modifier le profil" aria-label="Modifier le profil">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20h4l10.5-10.5a2.8 2.8 0 0 0-4-4L4 16v4Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                    </a>
                {% endif %}
            </div>
        </div>
    </section>

    {% if editForm %}
        <details class="card" id="edit-profile" style="padding:0;margin-top:14px;">
            <summary style="list-style:none;cursor:pointer;padding:16px 20px;display:flex;align-items:center;justify-content:space-between;gap:12px;font-weight:650;">
                <span style="display:inline-flex;align-items:center;gap:10px;">
                    <svg viewBox="0 0 24 24" fill="none" style="width:18px;height:18px;color:var(--primary-strong);" aria-hidden="true"><path d="M4 20h4l10.5-10.5a2.8 2.8 0 0 0-4-4L4 16v4Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                    Modifier mon profil
                </span>
                <svg viewBox="0 0 24 24" fill="none" style="width:16px;height:16px;color:var(--muted);transition:transform 180ms ease;" class="chevron" aria-hidden="true"><path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </summary>
            <div style="padding:0 20px 20px;border-top:1px solid var(--border);">
                {{ form_start(editForm) }}
                {{ form_row(editForm.bio, { label: 'Bio' }) }}
                {{ form_row(editForm.avatarUrl, { label: 'URL de l\'avatar' }) }}
                <div class="row" style="justify-content:flex-end;margin-top:8px;">
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                </div>
                {{ form_end(editForm) }}
            </div>
        </details>
        <style>
            #edit-profile[open] summary .chevron { transform: rotate(180deg); }
            #edit-profile > summary::-webkit-details-marker { display: none; }
            #edit-profile > summary::marker { display: none; }
            #edit-profile > summary:hover { background: var(--surface-ghost); }
            #edit-profile[open] > summary { border-bottom: 1px solid var(--border); }
        </style>
        <script>
            (function () {
                var panel = document.getElementById('edit-profile');
                if (!panel) return;
                if (window.location.hash === '#edit-profile') {
                    panel.open = true;
                }
                document.querySelectorAll('a[href="#edit-profile"]').forEach(function (link) {
                    link.addEventListener('click', function () {
                        panel.open = true;
                        setTimeout(function () {
                            panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        }, 10);
                    });
                });
            })();
        </script>
    {% endif %}

    <div class="page-header" style="margin-top:28px;">
        <h2 style="margin:0;">Posts</h2>
    </div>

    {% if posts is empty %}
        <div class="empty">
            <span class="empty-icon">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </span>
            <h3>Pas encore de publication</h3>
            <p>Quand {{ profileUser.username }} publiera, ses posts apparaîtront ici.</p>
        </div>
    {% endif %}

    <div class="stack">
        {% for post in posts %}
            <article class="card post-card">
                <div class="post-head">
                    <a class="avatar-inline" href="{{ path('app_profile_show', { username: profileUser.username }) }}" aria-hidden="true">
                        {% if profileUser.avatarUrl %}
                            <img src="{{ profileUser.avatarUrl }}" alt="">
                        {% else %}
                            {{ profileUser.username|slice(0, 1)|upper }}
                        {% endif %}
                    </a>
                    <div class="post-author">
                        <span class="author-link">{{ profileUser.username }}</span>
                        <span class="muted" style="font-size:12px;">{{ post.createdAt|date('d/m/Y · H:i') }}</span>
                    </div>
                </div>

                <p class="post-content">{{ post.content }}</p>

                <div class="post-footer">
                    <div class="action-row">
                        {% if app.user %}
                            {% set hasLiked = false %}
                            {% for u in post.likedBy %}
                                {% if u.id == app.user.id %}{% set hasLiked = true %}{% endif %}
                            {% endfor %}
                            <form method="post" action="{{ path('app_post_like_toggle', { id: post.id }) }}" class="inline-form">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('like' ~ post.id) }}">
                                <button type="submit" class="like-btn {{ hasLiked ? 'is-liked' : '' }}" aria-label="{{ hasLiked ? 'Ne plus liker' : 'Liker' }}">
                                    <svg viewBox="0 0 24 24" fill="{{ hasLiked ? 'currentColor' : 'none' }}" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M12 20s-7-4.5-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.5-7 10-7 10Z"/>
                                    </svg>
                                    <span>{{ post.likedBy|length }}</span>
                                </button>
                            </form>
                        {% else %}
                            <span class="muted" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:16px;height:16px;" aria-hidden="true"><path d="M12 20s-7-4.5-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.5-7 10-7 10Z"/></svg>
                                {{ post.likedBy|length }}
                            </span>
                        {% endif %}

                        {% if is_granted('POST_DELETE', post) %}
                            <form method="post" action="{{ path('app_post_delete', { id: post.id }) }}" class="inline-form">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete' ~ post.id) }}">
                                <button type="submit" class="btn btn-ghost btn-sm" aria-label="Supprimer le post">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16M9 7V5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2m-8 0 1 13a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2l1-13"/></svg>
                                    Supprimer
                                </button>
                            </form>
                        {% endif %}
                    </div>
                    <div class="post-date">{{ post.createdAt|date('d/m/Y H:i') }}</div>
                </div>
            </article>
        {% endfor %}
    </div>
{% endblock %}
