{% extends 'base.html.twig' %}

{% block title %}Profil{% endblock %}

{% block body %}
    <h1>Profil de {{ profileUser.username }}</h1>

    <section class="card">
        {% if profileUser.avatarUrl %}
            <img src="{{ profileUser.avatarUrl }}" alt="{{ profileUser.username }}" style="max-width: 96px; border-radius: 12px;">
        {% endif %}

        {% if profileUser.bio %}
            <p>{{ profileUser.bio }}</p>
        {% else %}
            <p class="muted">Aucune bio.</p>
        {% endif %}

        <p class="muted">
            <span>{{ followersCount }} followers</span>
            <span>·</span>
            <span>{{ followingCount }} follows</span>
        </p>

        {% if editForm %}
            <h2>Modifier mon profil</h2>
            <div class="card">
                {{ form_start(editForm) }}
                {{ form_row(editForm.bio, { label: 'Bio' }) }}
                {{ form_row(editForm.avatarUrl, { label: 'URL avatar' }) }}
                <button type="submit">Enregistrer</button>
                {{ form_end(editForm) }}
            </div>
        {% endif %}
        {% if app.user %}
            {% if app.user.id != profileUser.id %}
                {% if isFollowing %}
                    <form method="post" action="{{ path('app_profile_unfollow', { username: profileUser.username }) }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('unfollow' ~ profileUser.id) }}">
                        <button type="submit">Ne plus suivre</button>
                    </form>
                {% else %}
                    <form method="post" action="{{ path('app_profile_follow', { username: profileUser.username }) }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('follow' ~ profileUser.id) }}">
                        <button type="submit">Suivre</button>
                    </form>
                {% endif %}
            {% endif %}
        {% endif %}
    </section>

    <h2>Posts</h2>
    {% if posts is empty %}
        <p class="muted">Aucun post.</p>
    {% endif %}

    {% for post in posts %}
        <article class="card">
            <div class="muted">{{ post.createdAt|date('d/m/Y H:i') }}</div>
            <p>{{ post.content }}</p>

            <div class="muted">
                <span>{{ post.likedBy|length }} likes</span>
                {% if app.user %}
                    {% set hasLiked = false %}
                    {% for u in post.likedBy %}
                        {% if u.id == app.user.id %}
                            {% set hasLiked = true %}
                        {% endif %}
                    {% endfor %}

                    <form method="post" action="{{ path('app_post_like_toggle', { id: post.id }) }}" style="display: inline;">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('like' ~ post.id) }}">
                        <button type="submit">{{ hasLiked ? 'Ne plus liker' : 'Liker' }}</button>
                    </form>
                {% endif %}
            </div>

            {% if is_granted('POST_DELETE', post) %}
                <form method="post" action="{{ path('app_post_delete', { id: post.id }) }}" style="display: inline;">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete' ~ post.id) }}">
                    <button type="submit">Supprimer</button>
                </form>
            {% endif %}
        </article>
    {% endfor %}
{% endblock %}

